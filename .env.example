# Lidarr Configuration
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=your_api_key_here

# Optional (Highly recommended): Last.fm API Key for enhanced artist images & discovery
LASTFM_API_KEY=

# Contact Email (required for MusicBrainz API User-Agent)
CONTACT_EMAIL=user@example.com

# Backend Configuration
PORT=3001
DEBUG=false

# Frontend Configuration (for Kubernetes/GitOps deployments)
# These are optional - defaults to backend:3001 for Docker Compose compatibility
BACKEND_HOST=backend
BACKEND_PORT=3001